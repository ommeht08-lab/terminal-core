# Copy this file to .env and fill in real values for local development.
# If DATABASE_URL is unset, the app falls back to local SQLite (journal.db)
# automatically -- .env is only needed to point at a real Postgres instance.

# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated allowed CORS origins. Falls back to http://localhost:3000 if
# unset or empty.
# ALLOWED_ORIGINS=https://terminal-core.vercel.app,http://localhost:3000

# Required: price/OHLCV data (data_engine.py). Free tier: 5 requests/minute,
# ~2 years historical lookback, "today" is rejected on Grouped Daily until a
# paid plan. Get a key at https://polygon.io/
# POLYGON_API_KEY=

# Required: fundamentals/ratios/news (fundamental_metrics.py, quant_metrics.py).
# Free tier restricts some tickers entirely (e.g. BRK-B, LIN) and gates the
# news endpoint behind a paid plan -- both degrade gracefully to null/empty
# rather than erroring. Get a key at https://financialmodelingprep.com/
# FMP_API_KEY=

# Optional: read-only Algo Telemetry dashboard (alpaca_client.py). Paper
# trading credentials for the separate Java execution engine's Alpaca
# account -- this app never places or modifies orders, only reads positions
# and portfolio history. Left unset, /api/bot/* degrades to a "not
# configured" response instead of erroring. Create paper keys at
# https://app.alpaca.markets/paper/dashboard/overview
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
